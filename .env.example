# Optional: when set, data persists in Postgres instead of the local data/db.json file.
# Required in production so data survives restarts/redeploys. See README.md.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: when set, every page and API route requires this password (see proxy.ts).
# Strongly recommended in production — without it, the app is open to anyone with the URL.
APP_PASSWORD=changeme
